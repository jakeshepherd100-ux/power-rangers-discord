# Copy this file to .env and fill in your values.

ANTHROPIC_API_KEY=sk-ant-...

# Six Discord bot tokens (one per registered bot application)
DISCORD_TOKEN_THINKER=
DISCORD_TOKEN_BUILDER=
DISCORD_TOKEN_EMPATHIST=
DISCORD_TOKEN_PESSIMIST=
DISCORD_TOKEN_WILDCARD=
DISCORD_TOKEN_LEADER=

# The Discord channel ID where the agents operate (e.g. your #war-room)
TARGET_CHANNEL_ID=
